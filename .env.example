# Copy to .env — Expo loads EXPO_PUBLIC_* at build time.
# Production API (gateway behind https://verdict.sbs — configure nginx / proxy to Node).
EXPO_PUBLIC_API_URL=https://verdict.sbs
# Local dev (LAN IP for a physical device, not localhost):
# EXPO_PUBLIC_API_URL=http://192.168.x.x:3000

# Optional overrides (defaults live in constants/firebaseConfig.ts)
# EXPO_PUBLIC_FIREBASE_API_KEY=
# EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
# EXPO_PUBLIC_FIREBASE_PROJECT_ID=
# EXPO_PUBLIC_FIREBASE_STORAGE_BUCKET=
# EXPO_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# EXPO_PUBLIC_FIREBASE_APP_ID=
# EXPO_PUBLIC_FIREBASE_MEASUREMENT_ID=
